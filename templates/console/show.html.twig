{% extends 'base.html.twig' %}

{% block title %}{{ console.name }} - {{ parent() }}{% endblock %}

{% block body %}
    {# Header avec actions #}
    <div class="page-header">
        <div class="page-header-content">
            <a href="{{ path('app_console_index') }}" class="btn btn-outline btn-sm">
                ← Retour à la liste
            </a>

            <div class="btn-actions">
                {% if is_granted('edit', console) %}
                    <a href="{{ path('app_console_edit', {'id': console.id}) }}" class="btn btn-outline btn-sm">
                        ✏️ Modifier
                    </a>
                {% endif %}
                {% if is_granted('delete', console) %}
                    <form method="post" action="{{ path('app_console_delete', {'id': console.id}) }}" class="inline-form" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette console ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ console.id) }}">
                        <button type="submit" class="btn btn-danger btn-sm">🗑️ Supprimer</button>
                    </form>
                {% endif %}
            </div>
        </div>
    </div>

    {# Contenu principal #}
    <div class="detail-container">
        <div class="detail-main">
            {# Image de la console #}
            <div class="detail-image">
                {% if console.image %}
                    <img src="{{ console.image }}" alt="{{ console.name }}" class="detail-image-img">
                {% else %}
                    <div class="detail-image-placeholder">
                        <span class="placeholder-icon">🕹️</span>
                        <p>Aucune image</p>
                    </div>
                {% endif %}
            </div>

            {# Informations principales #}
            <div class="detail-content">
                <h1 class="detail-title">{{ console.name }}</h1>

                {# Tags rapides #}
                <div class="detail-tags">
                    <span class="tag tag-platform">🏭 {{ console.manufacturer }}</span>
                    <span class="tag tag-series">🎯 Génération {{ console.generation }}</span>
                </div>

                {# Informations détaillées #}
                <div class="detail-section">
                    <h2 class="detail-section-title">ℹ️ Informations</h2>
                    <div class="detail-info-grid">
                        <div class="info-item">
                            <span class="info-label">Fabricant</span>
                            <span class="info-value">{{ console.manufacturer }}</span>
                        </div>

                        <div class="info-item">
                            <span class="info-label">Génération</span>
                            <span class="info-value">{{ console.generation }}ᵉ génération</span>
                        </div>

                        {% if console.releaseDate %}
                            <div class="info-item">
                                <span class="info-label">Date de sortie</span>
                                <span class="info-value">{{ console.releaseDate|date('d/m/Y') }}</span>
                            </div>
                        {% endif %}

                        {% if console.maxPlayers %}
                            <div class="info-item">
                                <span class="info-label">Joueurs maximum</span>
                                <span class="info-value">{{ console.maxPlayers }} joueur{{ console.maxPlayers > 1 ? 's' : '' }}</span>
                            </div>
                        {% endif %}

                        {% if console.addedAt %}
                            <div class="info-item">
                                <span class="info-label">Ajoutée le</span>
                                <span class="info-value">{{ console.addedAt|date('d/m/Y à H:i') }}</span>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        {# Sidebar - Ajout à la collection #}
        {% if is_granted('ROLE_USER') %}
            <div class="detail-sidebar">
                <div class="collection-card">
                    <div class="collection-card-header">
                        <h3 class="collection-card-title">📦 Ma Collection</h3>
                    </div>

                    <div class="collection-card-body">
                        {% if my_collection %}
                            <div class="already-owned-badge">
                                <span class="owned-icon">✅</span>
                                <span>Déjà dans votre collection</span>
                            </div>
                            <form method="post" action="{{ path('app_console_update_in_collection', {'id': console.id}) }}" class="collection-form">
                                <div class="form__group">
                                    <label for="quantity" class="form__label">Nombre d'exemplaires</label>
                                    <div class="quantity-input">
                                        <button type="button" class="quantity-btn quantity-minus" onclick="decreaseQuantity()">−</button>
                                        <input type="number" id="quantity" name="quantity" class="quantity-field"
                                            value="{{ my_collection.quantity }}" min="1" max="99" required>
                                        <button type="button" class="quantity-btn quantity-plus" onclick="increaseQuantity()">+</button>
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-primary btn-block">
                                    💾 Mettre à jour
                                </button>
                            </form>
                            <form method="post" action="{{ path('app_console_update_in_collection', {'id': console.id}) }}"
                                  class="collection-form" style="margin-top:0.5rem;"
                                  onsubmit="return confirm('Retirer cette console de votre collection ?');">
                                <input type="hidden" name="action" value="remove">
                                <button type="submit" class="btn btn-danger btn-block btn-sm">
                                    🗑️ Retirer de ma collection
                                </button>
                            </form>
                        {% else %}
                            <form method="post" action="{{ path('app_console_add_to_collection', {'id': console.id}) }}" class="collection-form">
                                <div class="form__group">
                                    <label for="quantity" class="form__label">Nombre d'exemplaires</label>
                                    <div class="quantity-input">
                                        <button type="button" class="quantity-btn quantity-minus" onclick="decreaseQuantity()">−</button>
                                        <input type="number" id="quantity" name="quantity" class="quantity-field"
                                            value="1" min="1" max="99" required>
                                        <button type="button" class="quantity-btn quantity-plus" onclick="increaseQuantity()">+</button>
                                    </div>
                                    <small class="form-help">Indiquez combien d'exemplaires vous possédez</small>
                                </div>
                                <button type="submit" class="btn btn-primary btn-block">
                                    <span class="btn-icon">+</span> Ajouter à ma collection
                                </button>
                            </form>
                        {% endif %}
                    </div>

                    <div class="collection-card-footer">
                        <p class="collection-hint">
                            💡 Vous pourrez gérer vos consoles depuis votre collection
                        </p>

                        {# Collectionneurs #}
                        {% if console.consoleCollections is not empty %}
                        <details class="collectors-section">
                            <summary class="collectors-summary">
                                <i class="fas fa-users"></i>
                                Dans
                                <span class="collectors-count">{{ console.consoleCollections|length }}</span>
                                collection{{ console.consoleCollections|length > 1 ? 's' : '' }}
                                <i class="fas fa-chevron-down collectors-chevron"></i>
                            </summary>
                            <div class="collectors-list">
                                {% for col in console.consoleCollections %}
                                <div class="collector-row">
                                    <div class="collector-avatar">{{ col.user.username|slice(0,1) }}</div>
                                    <span class="collector-name">{{ col.user.username }}</span>
                                    <span class="collector-qty">
                                        <i class="fas fa-layer-group" style="margin-right:0;font-size:0.65rem;"></i>
                                        {{ col.quantity }}
                                    </span>
                                </div>
                                {% endfor %}
                            </div>
                        </details>
                        {% endif %}
                    </div>
                </div>

                {# Carte Kit Convention #}
                <div class="collection-card" style="margin-top: 1rem;">
                    <div class="collection-card-header">
                        <h3 class="collection-card-title">🎒 Mon Kit Convention</h3>
                    </div>
                    <div class="collection-card-body">
                        {% if my_kit %}
                            <div class="already-owned-badge">
                                <span class="owned-icon">✅</span>
                                <span>Déjà dans votre kit</span>
                            </div>
                            <form method="post" action="{{ path('app_console_update_in_kit', {'id': console.id}) }}" class="collection-form">
                                <div class="form__group">
                                    <label for="kit-quantity" class="form__label">Quantité</label>
                                    <div class="quantity-input">
                                        <button type="button" class="quantity-btn quantity-minus" onclick="decreaseKitQuantity()">−</button>
                                        <input type="number" id="kit-quantity" name="quantity" class="quantity-field"
                                            value="{{ my_kit.quantity }}" min="1" max="99" required>
                                        <button type="button" class="quantity-btn quantity-plus" onclick="increaseKitQuantity()">+</button>
                                    </div>
                                </div>
                                <div class="form__group">
                                    <label for="kit-note" class="form__label">Note (état, câbles...)</label>
                                    <textarea id="kit-note" name="note" class="form__input" rows="2" placeholder="État, câbles inclus...">{{ my_kit.note }}</textarea>
                                </div>
                                <button type="submit" class="btn btn-primary btn-block">💾 Mettre à jour</button>
                            </form>
                            <form method="post" action="{{ path('app_console_update_in_kit', {'id': console.id}) }}"
                                  class="collection-form" style="margin-top:0.5rem;"
                                  onsubmit="return confirm('Retirer cette console de votre kit ?');">
                                <input type="hidden" name="action" value="remove">
                                <button type="submit" class="btn btn-danger btn-block btn-sm">🗑️ Retirer du kit</button>
                            </form>
                        {% else %}
                            <form method="post" action="{{ path('app_console_add_to_kit', {'id': console.id}) }}" class="collection-form">
                                <div class="form__group">
                                    <label for="kit-quantity" class="form__label">Quantité</label>
                                    <div class="quantity-input">
                                        <button type="button" class="quantity-btn quantity-minus" onclick="decreaseKitQuantity()">−</button>
                                        <input type="number" id="kit-quantity" name="quantity" class="quantity-field"
                                            value="1" min="1" max="99" required>
                                        <button type="button" class="quantity-btn quantity-plus" onclick="increaseKitQuantity()">+</button>
                                    </div>
                                </div>
                                <div class="form__group">
                                    <label for="kit-note" class="form__label">Note (état, câbles...)</label>
                                    <textarea id="kit-note" name="note" class="form__input" rows="2" placeholder="État, câbles inclus..."></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary btn-block">
                                    <span class="btn-icon">+</span> Ajouter à mon kit
                                </button>
                            </form>
                        {% endif %}
                    </div>
                    <div class="collection-card-footer">
                        <p class="collection-hint">💡 Le kit recense le matériel confié par l'association</p>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>

    <script>
        function increaseQuantity() {
            const input = document.getElementById('quantity');
            const currentValue = parseInt(input.value) || 1;
            if (currentValue < 99) input.value = currentValue + 1;
        }
        function decreaseQuantity() {
            const input = document.getElementById('quantity');
            const currentValue = parseInt(input.value) || 1;
            if (currentValue > 1) input.value = currentValue - 1;
        }
        function increaseKitQuantity() {
            const input = document.getElementById('kit-quantity');
            const currentValue = parseInt(input.value) || 1;
            if (currentValue < 99) input.value = currentValue + 1;
        }
        function decreaseKitQuantity() {
            const input = document.getElementById('kit-quantity');
            const currentValue = parseInt(input.value) || 1;
            if (currentValue > 1) input.value = currentValue - 1;
        }
    </script>
{% endblock %}
