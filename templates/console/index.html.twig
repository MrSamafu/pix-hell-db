{% extends 'base.html.twig' %}

{% block title %}Consoles - {{ parent() }}{% endblock %}

{% block body %}
    <div class="page-header">
        <div class="page-header-content">
            <h1 class="page-title">
                <span class="icon">🕹️</span>
                Consoles
            </h1>
            {% if is_granted('ROLE_USER') %}
                <a href="{{ path('app_console_new') }}" class="btn btn-primary">
                    <span class="btn-icon">+</span>
                    <span class="hide-mobile">Ajouter une console</span>
                    <span class="hide-desktop">Ajouter</span>
                </a>
            {% endif %}
        </div>
    </div>

    <div class="search-container">
        <form method="get" action="{{ path('app_console_index') }}" class="search-form">
            <div class="search-bar">
                <div class="search-input-wrapper">
                    <span class="search-icon">🔍</span>
                    <input type="text" name="search" class="search-input"
                           placeholder="Nom, fabricant..."
                           value="{{ currentFilters.search ?? '' }}">
                    {% if currentFilters.search %}
                        <a href="{{ path('app_console_index') }}" class="search-clear" title="Effacer">✕</a>
                    {% endif %}
                </div>
                <button type="submit" class="btn btn-primary">Rechercher</button>
            </div>

            <div class="search-filters">
                <div class="filters-toggle" onclick="toggleFilters()">
                    <span class="filters-icon">⚙️</span>
                    <span class="filters-text">Filtres avancés</span>
                    <span class="filters-arrow" id="filters-arrow">▼</span>
                </div>
                <div class="filters-content" id="filters-content">
                    <div class="filters-grid">
                        <div class="filter-group">
                            <label for="manufacturer" class="filter-label">🏭 Fabricant</label>
                            <select name="manufacturer" id="manufacturer" class="filter-select">
                                <option value="">Tous les fabricants</option>
                                {% for manufacturer in manufacturers %}
                                    <option value="{{ manufacturer }}" {{ currentFilters.manufacturer == manufacturer ? 'selected' : '' }}>{{ manufacturer }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="filter-group">
                            <label for="generation" class="filter-label">🎯 Génération</label>
                            <select name="generation" id="generation" class="filter-select">
                                <option value="">Toutes les générations</option>
                                {% for generation in generations %}
                                    <option value="{{ generation }}" {{ currentFilters.generation == generation ? 'selected' : '' }}>{{ generation }}ᵉ génération</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="filter-group">
                            <label for="year" class="filter-label">📅 Année</label>
                            <select name="year" id="year" class="filter-select">
                                <option value="">Toutes les années</option>
                                {% for year in years %}
                                    <option value="{{ year }}" {{ currentFilters.year == year ? 'selected' : '' }}>{{ year }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                    <div class="filter-group alphabet-filter">
                        <label class="filter-label">🔤 Alphabétique</label>
                        <div class="alphabet-grid">
                            <a href="{{ path('app_console_index') }}" class="alphabet-btn {{ currentFilters.letter is empty ? 'active' : '' }}">Toutes</a>
                            {% for letter in alphabet %}
                                <a href="{{ path('app_console_index', {letter: letter}) }}" class="alphabet-btn {{ currentFilters.letter == letter ? 'active' : '' }}">{{ letter }}</a>
                            {% endfor %}
                        </div>
                    </div>
                    <div class="filters-actions">
                        <button type="submit" class="btn btn-primary">✓ Appliquer</button>
                        <a href="{{ path('app_console_index') }}" class="btn btn-outline">✕ Réinitialiser</a>
                    </div>
                </div>
            </div>
        </form>

        {% if currentFilters.search or currentFilters.manufacturer or currentFilters.generation or currentFilters.year or currentFilters.letter %}
        <div class="active-filters">
            <span class="active-filters-label">Filtres :</span>
            <div class="active-filters-list">
                {% if currentFilters.search %}<span class="filter-tag">🔍 "{{ currentFilters.search }}" <a href="{{ path('app_console_index', currentFilters|filter((v, k) => k != 'search')) }}" class="filter-tag-remove">✕</a></span>{% endif %}
                {% if currentFilters.manufacturer %}<span class="filter-tag">🏭 {{ currentFilters.manufacturer }} <a href="{{ path('app_console_index', currentFilters|filter((v, k) => k != 'manufacturer')) }}" class="filter-tag-remove">✕</a></span>{% endif %}
                {% if currentFilters.generation %}<span class="filter-tag">🎯 Gén. {{ currentFilters.generation }} <a href="{{ path('app_console_index', currentFilters|filter((v, k) => k != 'generation')) }}" class="filter-tag-remove">✕</a></span>{% endif %}
                {% if currentFilters.year %}<span class="filter-tag">📅 {{ currentFilters.year }} <a href="{{ path('app_console_index', currentFilters|filter((v, k) => k != 'year')) }}" class="filter-tag-remove">✕</a></span>{% endif %}
                {% if currentFilters.letter %}<span class="filter-tag">🔤 {{ currentFilters.letter }} <a href="{{ path('app_console_index', currentFilters|filter((v, k) => k != 'letter')) }}" class="filter-tag-remove">✕</a></span>{% endif %}
            </div>
        </div>
        {% endif %}

        <div class="search-results-count">
            <strong>{{ consoles|length }}</strong> console{{ consoles|length > 1 ? 's' : '' }} trouvée{{ consoles|length > 1 ? 's' : '' }}
        </div>
    </div>

    {% if consoles is empty %}
        <div class="empty-state">
            <div class="empty-state-icon">🕹️</div>
            <h2 class="empty-state-title">Aucune console pour le moment</h2>
            <p class="empty-state-text">Commencez à documenter votre collection de consoles !</p>
            {% if is_granted('ROLE_USER') %}
                <a href="{{ path('app_console_new') }}" class="btn btn-primary">Ajouter votre première console</a>
            {% endif %}
        </div>
    {% else %}
        <div class="catalog-grid">
            {% for console in consoles %}
                <div class="catalog-card">
                    <a href="{{ path('app_console_show', {'id': console.id}) }}" class="catalog-card__thumb">
                        {% if console.image %}
                            <img src="{{ console.image }}" alt="{{ console.name }}" class="catalog-card__img">
                        {% else %}
                            <div class="catalog-card__placeholder catalog-card__placeholder--console">
                                <i class="fas fa-desktop"></i>
                            </div>
                        {% endif %}
                    </a>

                    <div class="catalog-card__body">
                        <a href="{{ path('app_console_show', {'id': console.id}) }}" class="catalog-card__title">
                            {{ console.name }}
                        </a>
                        <div class="catalog-card__chips">
                            {% if console.manufacturer %}
                                <span class="catalog-chip catalog-chip--platform">
                                    <i class="fas fa-industry"></i> {{ console.manufacturer }}
                                </span>
                            {% endif %}
                            {% if console.releaseDate %}
                                <span class="catalog-chip">
                                    <i class="fas fa-calendar-alt"></i> {{ console.releaseDate|date('Y') }}
                                </span>
                            {% endif %}
                            {% if console.generation %}
                                <span class="catalog-chip catalog-chip--muted">
                                    <i class="fas fa-layer-group"></i> Gén. {{ console.generation }}
                                </span>
                            {% endif %}
                            {% if console.maxPlayers %}
                                <span class="catalog-chip catalog-chip--tag">
                                    <i class="fas fa-users"></i> {{ console.maxPlayers }}J
                                </span>
                            {% endif %}
                        </div>
                    </div>

                    <div class="catalog-card__actions">
                        {% if is_granted('edit', console) %}
                            <a href="{{ path('app_console_edit', {'id': console.id}) }}" class="catalog-action catalog-action--edit" title="Modifier">
                                <i class="fas fa-pencil-alt"></i>
                            </a>
                        {% endif %}
                        {% if is_granted('delete', console) %}
                            <form method="post" action="{{ path('app_console_delete', {'id': console.id}) }}" class="inline-form"
                                  onsubmit="return confirm('Supprimer cette console ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ console.id) }}">
                                <button type="submit" class="catalog-action catalog-action--delete" title="Supprimer">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    <script>
        function toggleFilters() {
            const content = document.getElementById('filters-content');
            const arrow = document.getElementById('filters-arrow');
            const open = content.style.display === 'block';
            content.style.display = open ? 'none' : 'block';
            arrow.textContent = open ? '▼' : '▲';
        }
        document.addEventListener('DOMContentLoaded', function () {
            const hasActiveFilters = {{ (currentFilters.manufacturer or currentFilters.generation or currentFilters.year) ? 'true' : 'false' }};
            if (hasActiveFilters) {
                document.getElementById('filters-content').style.display = 'block';
                document.getElementById('filters-arrow').textContent = '▲';
            }
        });
    </script>
{% endblock %}
