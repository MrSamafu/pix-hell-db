{% extends 'base.html.twig' %}

{% block title %}Accueil - {{ parent() }}{% endblock %}

{% block body %}
<div class="container">

    {# ══════════════════════════════════════════
       HERO
    ══════════════════════════════════════════ #}
    <div class="home-hero mb-xl">
        <div class="home-hero__content">
            <h1 class="home-hero__title">
                Pix<span>Hell</span>DB
            </h1>
            <p class="home-hero__sub">
                Votre gestionnaire de collection retrogaming
            </p>
        </div>
        <div class="home-hero__deco" aria-hidden="true">
            <span>🕹️</span>
        </div>
    </div>

    {# ══════════════════════════════════════════
       RACCOURCIS RAPIDES
    ══════════════════════════════════════════ #}
    <div class="home-shortcuts mb-xl">
        <a href="{{ path('app_game_index') }}" class="home-shortcut home-shortcut--games">
            <i class="fas fa-gamepad"></i>
            <span>Jeux</span>
        </a>
        <a href="{{ path('app_console_index') }}" class="home-shortcut home-shortcut--consoles">
            <i class="fas fa-desktop"></i>
            <span>Consoles</span>
        </a>
        <a href="{{ path('app_accessory_index') }}" class="home-shortcut home-shortcut--accessories">
            <i class="fas fa-plug"></i>
            <span>Accessoires</span>
        </a>
        <a href="{{ path('app_collection_index') }}" class="home-shortcut home-shortcut--collection">
            <i class="fas fa-folder-open"></i>
            <span>Collection</span>
        </a>
    </div>

    {# ══════════════════════════════════════════
       DERNIERS AJOUTS
    ══════════════════════════════════════════ #}
    {% if latest_items is defined and latest_items is not empty %}
    <div class="mb-xl">
        <div class="home-section-header mb-md">
            <h2 class="home-section-title">
                <i class="fas fa-fire"></i> Derniers ajouts
            </h2>
        </div>

        <div class="home-feed">
            {% for item in latest_items %}
                {% set entity = item.entity %}
                {% set collections = item.type == 'game' ? entity.gameCollections
                    : (item.type == 'console' ? entity.consoleCollections
                    : entity.accessoryCollections) %}

                <div class="home-feed-item animate-fade-in">

                    {# Miniature #}
                    <div class="home-feed-item__thumb">
                        {% if entity.image %}
                            <img src="{{ entity.image }}" alt="{{ entity.title ?? entity.name }}" class="home-feed-item__img">
                        {% else %}
                            <div class="home-feed-item__placeholder home-feed-item__placeholder--{{ item.type }}">
                                <i class="fas fa-{{ item.type == 'game' ? 'gamepad' : (item.type == 'console' ? 'desktop' : 'plug') }}"></i>
                            </div>
                        {% endif %}
                        <span class="home-feed-item__type-badge home-feed-item__type-badge--{{ item.type }}">
                            {{ item.type == 'game' ? 'Jeu' : (item.type == 'console' ? 'Console' : 'Accessoire') }}
                        </span>
                    </div>

                    {# Contenu #}
                    <div class="home-feed-item__body">
                        <a href="{{ path('app_' ~ item.type ~ '_show', {'id': entity.id}) }}" class="home-feed-item__title">
                            {{ entity.title ?? entity.name }}
                        </a>

                        <div class="home-feed-item__meta">
                            {% if item.type == 'game' and entity.platform %}
                                <span><i class="fas fa-desktop"></i> {{ entity.platform.name }}</span>
                            {% elseif item.type == 'accessory' and entity.compatibility %}
                                <span><i class="fas fa-link"></i> {{ entity.compatibility }}</span>
                            {% endif %}
                            <span><i class="fas fa-calendar-alt"></i> {{ item.date ? item.date|date('d/m/Y') : 'N/A' }}</span>
                            <span><i class="fas fa-user"></i> {{ entity.creator ? entity.creator.username : 'N/A' }}</span>
                        </div>

                        {% if collections is not empty %}
                        <details class="home-feed-item__collectors">
                            <summary>
                                <i class="fas fa-users"></i>
                                {{ collections|length }} collection{{ collections|length > 1 ? 's' : '' }}
                                <i class="fas fa-chevron-down home-feed-item__chevron"></i>
                            </summary>
                            <div class="home-feed-item__collectors-list">
                                {% for col in collections %}
                                <div class="home-feed-item__collector">
                                    <span class="home-feed-item__collector-avatar">{{ col.user.username|slice(0,1)|upper }}</span>
                                    <span class="home-feed-item__collector-name">{{ col.user.username }}</span>
                                    <span class="home-feed-item__collector-qty">×{{ col.quantity }}</span>
                                </div>
                                {% endfor %}
                            </div>
                        </details>
                        {% endif %}
                    </div>

                </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

</div>
{% endblock %}
