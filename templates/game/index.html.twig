{% extends 'base.html.twig' %}

{% block title %}Jeux Vidéo - {{ parent() }}{% endblock %}

{% block body %}
    <div class="page-header">
        <div class="page-header-content">
            <h1 class="page-title">
                <span class="icon">🎮</span>
                Jeux Vidéo
            </h1>
            {% if is_granted('ROLE_USER') %}
                <a href="{{ path('app_game_new') }}" class="btn btn-primary">
                    <span class="btn-icon">+</span>
                    <span class="hide-mobile">Ajouter un jeu</span>
                    <span class="hide-desktop">Ajouter</span>
                </a>
            {% endif %}
        </div>
    </div>

    {# Barre de recherche et filtres #}
    <div class="search-container">
        <form method="get" action="{{ path('app_game_index') }}" class="search-form">
            <div class="search-bar">
                <div class="search-input-wrapper">
                    <span class="search-icon">🔍</span>
                    <input type="text" name="search" class="search-input"
                           placeholder="Titre, série, éditeur, développeur..."
                           value="{{ currentFilters.search ?? '' }}">
                    {% if currentFilters.search %}
                        <a href="{{ path('app_game_index') }}" class="search-clear" title="Effacer">✕</a>
                    {% endif %}
                </div>
                <button type="submit" class="btn btn-primary">Rechercher</button>
            </div>

            <div class="search-filters">
                <div class="filters-toggle" onclick="toggleFilters()">
                    <span class="filters-icon">⚙️</span>
                    <span class="filters-text">Filtres avancés</span>
                    <span class="filters-arrow" id="filters-arrow">▼</span>
                </div>
                <div class="filters-content" id="filters-content">
                    <div class="filters-grid">
                        <div class="filter-group">
                            <label for="platform" class="filter-label">🕹️ Console</label>
                            <select name="platform" id="platform" class="filter-select">
                                <option value="">Toutes les consoles</option>
                                {% for console in consoles %}
                                    <option value="{{ console.id }}" {{ currentFilters.platform == console.id ? 'selected' : '' }}>{{ console.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="filter-group">
                            <label for="year" class="filter-label">📅 Année</label>
                            <select name="year" id="year" class="filter-select">
                                <option value="">Toutes les années</option>
                                {% for year in years %}
                                    <option value="{{ year }}" {{ currentFilters.year == year ? 'selected' : '' }}>{{ year }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="filter-group">
                            <label for="genre" class="filter-label">🎯 Genre</label>
                            <select name="genre" id="genre" class="filter-select">
                                <option value="">Tous les genres</option>
                                {% for genre in genres %}
                                    <option value="{{ genre.id }}" {{ currentFilters.genre == genre.id ? 'selected' : '' }}>{{ genre.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="filter-group">
                            <label for="mode" class="filter-label">🎮 Mode</label>
                            <select name="mode" id="mode" class="filter-select">
                                <option value="">Tous les modes</option>
                                {% for mode in modes %}
                                    <option value="{{ mode.id }}" {{ currentFilters.mode == mode.id ? 'selected' : '' }}>{{ mode.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                    <div class="filter-group alphabet-filter">
                        <label class="filter-label">🔤 Alphabétique</label>
                        <div class="alphabet-grid">
                            <a href="{{ path('app_game_index') }}" class="alphabet-btn {{ currentFilters.letter is empty ? 'active' : '' }}">Tous</a>
                            {% for letter in alphabet %}
                                <a href="{{ path('app_game_index', {letter: letter}) }}" class="alphabet-btn {{ currentFilters.letter == letter ? 'active' : '' }}">{{ letter }}</a>
                            {% endfor %}
                        </div>
                    </div>
                    <div class="filters-actions">
                        <button type="submit" class="btn btn-primary">✓ Appliquer</button>
                        <a href="{{ path('app_game_index') }}" class="btn btn-outline">✕ Réinitialiser</a>
                    </div>
                </div>
            </div>
        </form>

        {% if currentFilters.search or currentFilters.platform or currentFilters.year or currentFilters.genre or currentFilters.mode or currentFilters.letter %}
        <div class="active-filters">
            <span class="active-filters-label">Filtres :</span>
            <div class="active-filters-list">
                {% if currentFilters.search %}<span class="filter-tag">🔍 "{{ currentFilters.search }}" <a href="{{ path('app_game_index', currentFilters|filter((v, k) => k != 'search')) }}" class="filter-tag-remove">✕</a></span>{% endif %}
                {% if currentFilters.platform %}<span class="filter-tag">🕹️ Console <a href="{{ path('app_game_index', currentFilters|filter((v, k) => k != 'platform')) }}" class="filter-tag-remove">✕</a></span>{% endif %}
                {% if currentFilters.year %}<span class="filter-tag">📅 {{ currentFilters.year }} <a href="{{ path('app_game_index', currentFilters|filter((v, k) => k != 'year')) }}" class="filter-tag-remove">✕</a></span>{% endif %}
                {% if currentFilters.genre %}<span class="filter-tag">🎯 Genre <a href="{{ path('app_game_index', currentFilters|filter((v, k) => k != 'genre')) }}" class="filter-tag-remove">✕</a></span>{% endif %}
                {% if currentFilters.mode %}<span class="filter-tag">🎮 Mode <a href="{{ path('app_game_index', currentFilters|filter((v, k) => k != 'mode')) }}" class="filter-tag-remove">✕</a></span>{% endif %}
                {% if currentFilters.letter %}<span class="filter-tag">🔤 {{ currentFilters.letter }} <a href="{{ path('app_game_index', currentFilters|filter((v, k) => k != 'letter')) }}" class="filter-tag-remove">✕</a></span>{% endif %}
            </div>
        </div>
        {% endif %}

        <div class="search-results-count">
            <strong>{{ games|length }}</strong> jeu{{ games|length > 1 ? 'x' : '' }} trouvé{{ games|length > 1 ? 's' : '' }}
        </div>
    </div>

    {% if games is empty %}
        <div class="empty-state">
            <div class="empty-state-icon">🎮</div>
            <h2 class="empty-state-title">Aucun jeu pour le moment</h2>
            <p class="empty-state-text">Commencez à construire votre bibliothèque de jeux !</p>
            {% if is_granted('ROLE_USER') %}
                <a href="{{ path('app_game_new') }}" class="btn btn-primary">Ajouter votre premier jeu</a>
            {% endif %}
        </div>
    {% else %}
        <div class="catalog-grid">
            {% for game in games %}
                <div class="catalog-card">
                    {# Vignette #}
                    <a href="{{ path('app_game_show', {'id': game.id}) }}" class="catalog-card__thumb">
                        {% if game.image %}
                            <img src="{{ game.image }}" alt="{{ game.title }}" class="catalog-card__img">
                        {% else %}
                            <div class="catalog-card__placeholder catalog-card__placeholder--game">
                                <i class="fas fa-gamepad"></i>
                            </div>
                        {% endif %}
                    </a>

                    {# Contenu #}
                    <div class="catalog-card__body">
                        <a href="{{ path('app_game_show', {'id': game.id}) }}" class="catalog-card__title">
                            {{ game.title }}
                        </a>

                        <div class="catalog-card__chips">
                            {% if game.platform %}
                                <span class="catalog-chip catalog-chip--platform">
                                    <i class="fas fa-desktop"></i> {{ game.platform.name }}
                                </span>
                            {% endif %}
                            {% if game.releaseDate %}
                                <span class="catalog-chip">
                                    <i class="fas fa-calendar-alt"></i> {{ game.releaseDate|date('Y') }}
                                </span>
                            {% endif %}
                            {% if game.developer %}
                                <span class="catalog-chip catalog-chip--muted">
                                    <i class="fas fa-code"></i> {{ game.developer }}
                                </span>
                            {% endif %}
                            {% for genre in game.genres|slice(0, 2) %}
                                <span class="catalog-chip catalog-chip--tag">{{ genre.name }}</span>
                            {% endfor %}
                            {% if game.genres|length > 2 %}
                                <span class="catalog-chip catalog-chip--more">+{{ game.genres|length - 2 }}</span>
                            {% endif %}
                        </div>
                    </div>

                    {# Actions #}
                    <div class="catalog-card__actions">
                        {% if is_granted('edit', game) %}
                            <a href="{{ path('app_game_edit', {'id': game.id}) }}" class="catalog-action catalog-action--edit" title="Modifier">
                                <i class="fas fa-pencil-alt"></i>
                            </a>
                        {% endif %}
                        {% if is_granted('delete', game) %}
                            <form method="post" action="{{ path('app_game_delete', {'id': game.id}) }}" class="inline-form"
                                  onsubmit="return confirm('Supprimer ce jeu ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ game.id) }}">
                                <button type="submit" class="catalog-action catalog-action--delete" title="Supprimer">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    <script>
        function toggleFilters() {
            const content = document.getElementById('filters-content');
            const arrow = document.getElementById('filters-arrow');
            const open = content.style.display === 'block';
            content.style.display = open ? 'none' : 'block';
            arrow.textContent = open ? '▼' : '▲';
        }
        document.addEventListener('DOMContentLoaded', function () {
            const hasActiveFilters = {{ (currentFilters.platform or currentFilters.year or currentFilters.genre or currentFilters.mode) ? 'true' : 'false' }};
            if (hasActiveFilters) {
                document.getElementById('filters-content').style.display = 'block';
                document.getElementById('filters-arrow').textContent = '▲';
            }
        });
    </script>
{% endblock %}
