{% extends 'base.html.twig' %}

{% block title %}{{ game.title }} - {{ parent() }}{% endblock %}

{% block body %}
    {# Header avec actions #}
    <div class="page-header">
        <div class="page-header-content">
            <a href="{{ path('app_game_index') }}" class="btn btn-outline btn-sm">
                ← Retour à la liste
            </a>

            <div class="btn-actions">
                {% if is_granted('edit', game) %}
                    <a href="{{ path('app_game_edit', {'id': game.id}) }}" class="btn btn-outline btn-sm">
                        ✏️ Modifier
                    </a>
                {% endif %}
                {% if is_granted('delete', game) %}
                    <form method="post" action="{{ path('app_game_delete', {'id': game.id}) }}" class="inline-form" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce jeu ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ game.id) }}">
                        <button type="submit" class="btn btn-danger btn-sm">🗑️ Supprimer</button>
                    </form>
                {% endif %}
            </div>
        </div>
    </div>

    {# Contenu principal #}
    <div class="detail-container">
        <div class="detail-main">
            {# Image du jeu #}
            <div class="detail-image">
                {% if game.image %}
                    <img src="{{ game.image }}" alt="{{ game.title }}" class="detail-image-img">
                {% else %}
                    <div class="detail-image-placeholder">
                        <span class="placeholder-icon">🎮</span>
                        <p>Aucune image</p>
                    </div>
                {% endif %}
            </div>

            {# Informations principales #}
            <div class="detail-content">
                <h1 class="detail-title">{{ game.title }}</h1>

                {# Tags rapides #}
                <div class="detail-tags">
                    {% if game.platform %}
                        <span class="tag tag-platform">🕹️ {{ game.platform.name }}</span>
                    {% endif %}
                    {% if game.series %}
                        <span class="tag tag-series">📚 {{ game.series }}</span>
                    {% endif %}
                </div>

                {# Description #}
                {% if game.description %}
                    <div class="detail-section">
                        <h2 class="detail-section-title">📖 Description</h2>
                        <p class="detail-description">{{ game.description|nl2br }}</p>
                    </div>
                {% endif %}

                {# Informations détaillées #}
                <div class="detail-section">
                    <h2 class="detail-section-title">ℹ️ Informations</h2>
                    <div class="detail-info-grid">
                        {% if game.developer %}
                            <div class="info-item">
                                <span class="info-label">Développeur</span>
                                <span class="info-value">{{ game.developer }}</span>
                            </div>
                        {% endif %}

                        {% if game.publisher %}
                            <div class="info-item">
                                <span class="info-label">Éditeur</span>
                                <span class="info-value">{{ game.publisher }}</span>
                            </div>
                        {% endif %}

                        {% if game.releaseDate %}
                            <div class="info-item">
                                <span class="info-label">Date de sortie</span>
                                <span class="info-value">{{ game.releaseDate|date('d/m/Y') }}</span>
                            </div>
                        {% endif %}

                        {% if game.createdAt %}
                            <div class="info-item">
                                <span class="info-label">Ajouté le</span>
                                <span class="info-value">{{ game.createdAt|date('d/m/Y à H:i') }}</span>
                            </div>
                        {% endif %}
                    </div>
                </div>

                {# Genres #}
                {% if game.genres is not empty %}
                    <div class="detail-section">
                        <h2 class="detail-section-title">🎯 Genres</h2>
                        <div class="card-tags">
                            {% for genre in game.genres %}
                                <span class="tag">{{ genre.name }}</span>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                {# Modes de jeu #}
                {% if game.modes is not empty %}
                    <div class="detail-section">
                        <h2 class="detail-section-title">🎮 Modes de jeu</h2>
                        <div class="card-tags">
                            {% for mode in game.modes %}
                                <span class="tag">{{ mode.name }}</span>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>

        {# Sidebar - Ajout à la collection #}
        {% if is_granted('ROLE_USER') %}
            <div class="detail-sidebar">
                <div class="collection-card">
                    <div class="collection-card-header">
                        <h3 class="collection-card-title">📦 Ma Collection</h3>
                    </div>

                    <div class="collection-card-body">
                        {% if my_collection %}
                            {# Déjà dans la collection : afficher quantité + modifier #}
                            <div class="already-owned-badge">
                                <span class="owned-icon">✅</span>
                                <span>Déjà dans votre collection</span>
                            </div>
                            <form method="post" action="{{ path('app_game_update_in_collection', {'id': game.id}) }}" class="collection-form">
                                <div class="form__group">
                                    <label for="quantity" class="form__label">Nombre d'exemplaires</label>
                                    <div class="quantity-input">
                                        <button type="button" class="quantity-btn quantity-minus" onclick="decreaseQuantity()">−</button>
                                        <input type="number" id="quantity" name="quantity" class="quantity-field"
                                            value="{{ my_collection.quantity }}" min="1" max="99" required>
                                        <button type="button" class="quantity-btn quantity-plus" onclick="increaseQuantity()">+</button>
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-primary btn-block">
                                    💾 Mettre à jour
                                </button>
                            </form>
                            <form method="post" action="{{ path('app_game_update_in_collection', {'id': game.id}) }}"
                                  class="collection-form" style="margin-top:0.5rem;"
                                  onsubmit="return confirm('Retirer ce jeu de votre collection ?');">
                                <input type="hidden" name="action" value="remove">
                                <button type="submit" class="btn btn-danger btn-block btn-sm">
                                    🗑️ Retirer de ma collection
                                </button>
                            </form>
                        {% else %}
                            {# Pas encore dans la collection : formulaire d'ajout #}
                            <form method="post" action="{{ path('app_game_add_to_collection', {'id': game.id}) }}" class="collection-form">
                                <div class="form__group">
                                    <label for="quantity" class="form__label">Nombre d'exemplaires</label>
                                    <div class="quantity-input">
                                        <button type="button" class="quantity-btn quantity-minus" onclick="decreaseQuantity()">−</button>
                                        <input type="number" id="quantity" name="quantity" class="quantity-field"
                                            value="1" min="1" max="99" required>
                                        <button type="button" class="quantity-btn quantity-plus" onclick="increaseQuantity()">+</button>
                                    </div>
                                    <small class="form-help">Indiquez combien d'exemplaires vous possédez</small>
                                </div>
                                <button type="submit" class="btn btn-primary btn-block">
                                    <span class="btn-icon">+</span> Ajouter à ma collection
                                </button>
                            </form>
                        {% endif %}
                    </div>

                    <div class="collection-card-footer">
                        <p class="collection-hint">
                            💡 Vous pourrez gérer vos jeux depuis votre collection
                        </p>

                        {# Collectionneurs #}
                        {% if game.gameCollections is not empty %}
                        <details class="collectors-section">
                            <summary class="collectors-summary">
                                <i class="fas fa-users"></i>
                                Dans
                                <span class="collectors-count">{{ game.gameCollections|length }}</span>
                                collection{{ game.gameCollections|length > 1 ? 's' : '' }}
                                <i class="fas fa-chevron-down collectors-chevron"></i>
                            </summary>
                            <div class="collectors-list">
                                {% for col in game.gameCollections %}
                                <div class="collector-row">
                                    <div class="collector-avatar">{{ col.user.username|slice(0,1) }}</div>
                                    <span class="collector-name">{{ col.user.username }}</span>
                                    <span class="collector-qty">
                                        <i class="fas fa-layer-group" style="margin-right:0;font-size:0.65rem;"></i>
                                        {{ col.quantity }}
                                    </span>
                                </div>
                                {% endfor %}
                            </div>
                        </details>
                        {% endif %}
                    </div>
                </div>

                {# Carte Kit Convention #}
                <div class="collection-card" style="margin-top: 1rem;">
                    <div class="collection-card-header">
                        <h3 class="collection-card-title">🎒 Mon Kit Convention</h3>
                    </div>
                    <div class="collection-card-body">
                        {% if my_kit %}
                            <div class="already-owned-badge">
                                <span class="owned-icon">✅</span>
                                <span>Déjà dans votre kit</span>
                            </div>
                            <form method="post" action="{{ path('app_game_update_in_kit', {'id': game.id}) }}" class="collection-form">
                                <div class="form__group">
                                    <label for="kit-quantity" class="form__label">Quantité</label>
                                    <div class="quantity-input">
                                        <button type="button" class="quantity-btn quantity-minus" onclick="decreaseKitQuantity()">−</button>
                                        <input type="number" id="kit-quantity" name="quantity" class="quantity-field"
                                            value="{{ my_kit.quantity }}" min="1" max="99" required>
                                        <button type="button" class="quantity-btn quantity-plus" onclick="increaseKitQuantity()">+</button>
                                    </div>
                                </div>
                                <div class="form__group">
                                    <label for="kit-note" class="form__label">Note (état, câbles...)</label>
                                    <textarea id="kit-note" name="note" class="form__input" rows="2" placeholder="État, câbles inclus...">{{ my_kit.note }}</textarea>
                                </div>
                                <button type="submit" class="btn btn-primary btn-block">💾 Mettre à jour</button>
                            </form>
                            <form method="post" action="{{ path('app_game_update_in_kit', {'id': game.id}) }}"
                                  class="collection-form" style="margin-top:0.5rem;"
                                  onsubmit="return confirm('Retirer ce jeu de votre kit ?');">
                                <input type="hidden" name="action" value="remove">
                                <button type="submit" class="btn btn-danger btn-block btn-sm">🗑️ Retirer du kit</button>
                            </form>
                        {% else %}
                            <form method="post" action="{{ path('app_game_add_to_kit', {'id': game.id}) }}" class="collection-form">
                                <div class="form__group">
                                    <label for="kit-quantity" class="form__label">Quantité</label>
                                    <div class="quantity-input">
                                        <button type="button" class="quantity-btn quantity-minus" onclick="decreaseKitQuantity()">−</button>
                                        <input type="number" id="kit-quantity" name="quantity" class="quantity-field"
                                            value="1" min="1" max="99" required>
                                        <button type="button" class="quantity-btn quantity-plus" onclick="increaseKitQuantity()">+</button>
                                    </div>
                                </div>
                                <div class="form__group">
                                    <label for="kit-note" class="form__label">Note (état, câbles...)</label>
                                    <textarea id="kit-note" name="note" class="form__input" rows="2" placeholder="État, câbles inclus..."></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary btn-block">
                                    <span class="btn-icon">+</span> Ajouter à mon kit
                                </button>
                            </form>
                        {% endif %}
                    </div>
                    <div class="collection-card-footer">
                        <p class="collection-hint">💡 Le kit recense le matériel confié par l'association</p>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>

    <script>
        function increaseQuantity() {
            const input = document.getElementById('quantity');
            const currentValue = parseInt(input.value) || 1;
            if (currentValue < 99) input.value = currentValue + 1;
        }
        function decreaseQuantity() {
            const input = document.getElementById('quantity');
            const currentValue = parseInt(input.value) || 1;
            if (currentValue > 1) input.value = currentValue - 1;
        }
        function increaseKitQuantity() {
            const input = document.getElementById('kit-quantity');
            const currentValue = parseInt(input.value) || 1;
            if (currentValue < 99) input.value = currentValue + 1;
        }
        function decreaseKitQuantity() {
            const input = document.getElementById('kit-quantity');
            const currentValue = parseInt(input.value) || 1;
            if (currentValue > 1) input.value = currentValue - 1;
        }
    </script>
{% endblock %}
