{% extends 'base.html.twig' %}

{% block title %}{{ accessory.name }} - {{ parent() }}{% endblock %}

{% block body %}
    {# Header avec actions #}
    <div class="page-header">
        <div class="page-header-content">
            <a href="{{ path('app_accessory_index') }}" class="btn btn-outline btn-sm">
                ← Retour à la liste
            </a>

            <div class="btn-actions">
                {% if is_granted('edit', accessory) %}
                    <a href="{{ path('app_accessory_edit', {'id': accessory.id}) }}" class="btn btn-outline btn-sm">
                        ✏️ Modifier
                    </a>
                {% endif %}
                {% if is_granted('delete', accessory) %}
                    <form method="post" action="{{ path('app_accessory_delete', {'id': accessory.id}) }}" class="inline-form" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet accessoire ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ accessory.id) }}">
                        <button type="submit" class="btn btn-danger btn-sm">🗑️ Supprimer</button>
                    </form>
                {% endif %}
            </div>
        </div>
    </div>

    {# Contenu principal #}
    <div class="detail-container">
        <div class="detail-main">
            {# Image de l'accessoire #}
            <div class="detail-image">
                {% if accessory.image %}
                    <img src="{{ accessory.image }}" alt="{{ accessory.name }}" class="detail-image-img">
                {% else %}
                    <div class="detail-image-placeholder">
                        <span class="placeholder-icon">🎧</span>
                        <p>Aucune image</p>
                    </div>
                {% endif %}
            </div>

            {# Informations principales #}
            <div class="detail-content">
                <h1 class="detail-title">{{ accessory.name }}</h1>

                {# Tags rapides #}
                <div class="detail-tags">
                    <span class="tag tag-platform">🎮 {{ accessory.type }}</span>
                    {% if accessory.compatibility %}
                        <span class="tag tag-series">🔗 {{ accessory.compatibility }}</span>
                    {% endif %}
                </div>

                {# Informations détaillées #}
                <div class="detail-section">
                    <h2 class="detail-section-title">ℹ️ Informations</h2>
                    <div class="detail-info-grid">
                        <div class="info-item">
                            <span class="info-label">Type</span>
                            <span class="info-value">{{ accessory.type }}</span>
                        </div>

                        <div class="info-item">
                            <span class="info-label">Compatibilité</span>
                            <span class="info-value">{{ accessory.compatibility }}</span>
                        </div>

                        {% if accessory.releaseDate %}
                            <div class="info-item">
                                <span class="info-label">Date de sortie</span>
                                <span class="info-value">{{ accessory.releaseDate|date('d/m/Y') }}</span>
                            </div>
                        {% endif %}

                        {% if accessory.createdAt %}
                            <div class="info-item">
                                <span class="info-label">Ajouté le</span>
                                <span class="info-value">{{ accessory.createdAt|date('d/m/Y à H:i') }}</span>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        {# Sidebar - Ajout à la collection #}
        {% if is_granted('ROLE_USER') %}
            <div class="detail-sidebar">
                <div class="collection-card">
                    <div class="collection-card-header">
                        <h3 class="collection-card-title">📦 Ma Collection</h3>
                    </div>

                    <div class="collection-card-body">
                        {% if my_collection %}
                            <div class="already-owned-badge">
                                <span class="owned-icon">✅</span>
                                <span>Déjà dans votre collection</span>
                            </div>
                            <form method="post" action="{{ path('app_accessory_update_in_collection', {'id': accessory.id}) }}" class="collection-form">
                                <div class="form__group">
                                    <label for="quantity" class="form__label">Nombre d'exemplaires</label>
                                    <div class="quantity-input">
                                        <button type="button" class="quantity-btn quantity-minus" onclick="decreaseQuantity()">−</button>
                                        <input type="number" id="quantity" name="quantity" class="quantity-field"
                                            value="{{ my_collection.quantity }}" min="1" max="99" required>
                                        <button type="button" class="quantity-btn quantity-plus" onclick="increaseQuantity()">+</button>
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-primary btn-block">
                                    💾 Mettre à jour
                                </button>
                            </form>
                            <form method="post" action="{{ path('app_accessory_update_in_collection', {'id': accessory.id}) }}"
                                  class="collection-form" style="margin-top:0.5rem;"
                                  onsubmit="return confirm('Retirer cet accessoire de votre collection ?');">
                                <input type="hidden" name="action" value="remove">
                                <button type="submit" class="btn btn-danger btn-block btn-sm">
                                    🗑️ Retirer de ma collection
                                </button>
                            </form>
                        {% else %}
                            <form method="post" action="{{ path('app_accessory_add_to_collection', {'id': accessory.id}) }}" class="collection-form">
                                <div class="form__group">
                                    <label for="quantity" class="form__label">Nombre d'exemplaires</label>
                                    <div class="quantity-input">
                                        <button type="button" class="quantity-btn quantity-minus" onclick="decreaseQuantity()">−</button>
                                        <input type="number" id="quantity" name="quantity" class="quantity-field"
                                            value="1" min="1" max="99" required>
                                        <button type="button" class="quantity-btn quantity-plus" onclick="increaseQuantity()">+</button>
                                    </div>
                                    <small class="form-help">Indiquez combien d'exemplaires vous possédez</small>
                                </div>
                                <button type="submit" class="btn btn-primary btn-block">
                                    <span class="btn-icon">+</span> Ajouter à ma collection
                                </button>
                            </form>
                        {% endif %}
                    </div>

                    <div class="collection-card-footer">
                        <p class="collection-hint">
                            💡 Vous pourrez gérer vos accessoires depuis votre collection
                        </p>

                        {# Collectionneurs #}
                        {% if accessory.accessoryCollections is not empty %}
                        <details class="collectors-section">
                            <summary class="collectors-summary">
                                <i class="fas fa-users"></i>
                                Dans
                                <span class="collectors-count">{{ accessory.accessoryCollections|length }}</span>
                                collection{{ accessory.accessoryCollections|length > 1 ? 's' : '' }}
                                <i class="fas fa-chevron-down collectors-chevron"></i>
                            </summary>
                            <div class="collectors-list">
                                {% for col in accessory.accessoryCollections %}
                                <div class="collector-row">
                                    <div class="collector-avatar">{{ col.user.username|slice(0,1) }}</div>
                                    <span class="collector-name">{{ col.user.username }}</span>
                                    <span class="collector-qty">
                                        <i class="fas fa-layer-group" style="margin-right:0;font-size:0.65rem;"></i>
                                        {{ col.quantity }}
                                    </span>
                                </div>
                                {% endfor %}
                            </div>
                        </details>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endif %}
    </div>

    <script>
        function increaseQuantity() {
            const input = document.getElementById('quantity');
            const currentValue = parseInt(input.value) || 1;
            if (currentValue < 99) {
                input.value = currentValue + 1;
            }
        }

        function decreaseQuantity() {
            const input = document.getElementById('quantity');
            const currentValue = parseInt(input.value) || 1;
            if (currentValue > 1) {
                input.value = currentValue - 1;
            }
        }
    </script>
{% endblock %}
