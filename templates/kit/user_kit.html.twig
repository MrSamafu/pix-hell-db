{% extends 'base.html.twig' %}

{% block title %}Kit de {{ user.username }} - {{ parent() }}{% endblock %}

{% block body %}
    <div class="page-header">
        <div class="page-header-content">
            <h1 class="page-title">
                <span class="icon">🎒</span>
                Kit de {{ user.username }}
            </h1>
            <a href="{{ path('app_kit_index') }}" class="btn btn--secondary">
                ← Retour
            </a>
        </div>
    </div>

    <div class="container">
        <!-- Statistiques -->
        <div class="collection-stats mb-xl">
            <div class="stat-card">
                <div class="stat-icon">🎮</div>
                <div class="stat-value">{{ total_games }}</div>
                <div class="stat-label">Jeux</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">📺</div>
                <div class="stat-value">{{ total_consoles }}</div>
                <div class="stat-label">Consoles</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">🎧</div>
                <div class="stat-value">{{ total_accessories }}</div>
                <div class="stat-label">Accessoires</div>
            </div>
        </div>

        <!-- Onglets -->
        <ul class="nav nav-tabs mb-lg" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#games" type="button" role="tab">
                    🎮 Jeux <span class="badge badge--primary ml-sm">{{ game_kits|length }}</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#consoles" type="button" role="tab">
                    📺 Consoles <span class="badge badge--secondary ml-sm">{{ console_kits|length }}</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#accessories" type="button" role="tab">
                    🎧 Accessoires <span class="badge badge--accent ml-sm">{{ accessory_kits|length }}</span>
                </button>
            </li>
        </ul>

        <div class="tab-content">
            <!-- Jeux -->
            <div class="tab-pane fade show active" id="games" role="tabpanel">
                {% if game_kits %}
                    <div class="grid grid--3">
                        {% for kit in game_kits %}
                            <div class="card">
                                {% if kit.game.image %}
                                    <img src="{{ kit.game.image }}" class="card__image" alt="{{ kit.game.title }}">
                                {% else %}
                                    <div class="card__image" style="display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,rgba(103,97,168,.3),rgba(160,193,185,.3));">
                                        <span style="font-size:3rem;opacity:.5;">🎮</span>
                                    </div>
                                {% endif %}
                                <div class="card__body">
                                    <h3 class="card__title">{{ kit.game.title }}</h3>
                                    <p class="card__text text--muted"><small>{{ kit.game.platform.name ?? 'N/A' }}</small></p>
                                    <p class="card__text"><strong>Quantité :</strong> {{ kit.quantity }}</p>
                                    {% if kit.note %}<p class="card__text text--muted"><em>{{ kit.note }}</em></p>{% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text--center" style="padding:3rem;">
                        <p class="text--muted">Aucun jeu dans le kit de {{ user.username }}</p>
                    </div>
                {% endif %}
            </div>

            <!-- Consoles -->
            <div class="tab-pane fade" id="consoles" role="tabpanel">
                {% if console_kits %}
                    <div class="grid grid--3">
                        {% for kit in console_kits %}
                            <div class="card">
                                {% if kit.console.image %}
                                    <img src="{{ kit.console.image }}" class="card__image" alt="{{ kit.console.name }}">
                                {% else %}
                                    <div class="card__image" style="display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,rgba(160,193,185,.3),rgba(103,97,168,.3));">
                                        <span style="font-size:3rem;opacity:.5;">📺</span>
                                    </div>
                                {% endif %}
                                <div class="card__body">
                                    <h3 class="card__title">{{ kit.console.name }}</h3>
                                    <p class="card__text text--muted"><small>{{ kit.console.manufacturer ?? 'N/A' }}</small></p>
                                    <p class="card__text"><strong>Quantité :</strong> {{ kit.quantity }}</p>
                                    {% if kit.note %}<p class="card__text text--muted"><em>{{ kit.note }}</em></p>{% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text--center" style="padding:3rem;">
                        <p class="text--muted">Aucune console dans le kit de {{ user.username }}</p>
                    </div>
                {% endif %}
            </div>

            <!-- Accessoires -->
            <div class="tab-pane fade" id="accessories" role="tabpanel">
                {% if accessory_kits %}
                    <div class="grid grid--3">
                        {% for kit in accessory_kits %}
                            <div class="card">
                                {% if kit.accessory.image %}
                                    <img src="{{ kit.accessory.image }}" class="card__image" alt="{{ kit.accessory.name }}">
                                {% else %}
                                    <div class="card__image" style="display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,rgba(163,0,21,.3),rgba(103,97,168,.3));">
                                        <span style="font-size:3rem;opacity:.5;">🎧</span>
                                    </div>
                                {% endif %}
                                <div class="card__body">
                                    <h3 class="card__title">{{ kit.accessory.name }}</h3>
                                    <p class="card__text text--muted"><small>{{ kit.accessory.type ?? 'N/A' }}</small></p>
                                    <p class="card__text"><strong>Quantité :</strong> {{ kit.quantity }}</p>
                                    {% if kit.note %}<p class="card__text text--muted"><em>{{ kit.note }}</em></p>{% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text--center" style="padding:3rem;">
                        <p class="text--muted">Aucun accessoire dans le kit de {{ user.username }}</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}

