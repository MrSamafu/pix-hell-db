{% extends 'base.html.twig' %}

{% block title %}Mon Kit Convention - {{ parent() }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('kit') }}
{% endblock %}

{% block body %}

{# Config JS via data-attributes #}
<div id="kit-config" hidden
     data-games-url="{{ path('app_kit_api_games') }}"
     data-consoles-url="{{ path('app_kit_api_consoles') }}"
     data-accessories-url="{{ path('app_kit_api_accessories') }}">
</div>

{# ---- Header ---- #}
<div class="coll-hero">
    <div class="coll-hero__icon">
        <i class="fas fa-briefcase"></i>
    </div>
    <div class="coll-hero__text">
        <h1 class="coll-hero__title">Mon Kit Convention</h1>
        <p class="coll-hero__sub">Matériel que vous apportez lors des conventions</p>
    </div>
    <a href="{{ path('app_kit_index') }}" class="btn-outline coll-hero__back">
        <i class="fas fa-arrow-left"></i> Retour
    </a>
</div>

{# ---- Stats ---- #}
<div class="coll-stats">
    <div class="coll-stat coll-stat--games">
        <i class="fas fa-gamepad coll-stat__icon"></i>
        <span class="coll-stat__value">{{ total_games }}</span>
        <span class="coll-stat__label">Jeux</span>
    </div>
    <div class="coll-stat coll-stat--consoles">
        <i class="fas fa-desktop coll-stat__icon"></i>
        <span class="coll-stat__value">{{ total_consoles }}</span>
        <span class="coll-stat__label">Consoles</span>
    </div>
    <div class="coll-stat coll-stat--accessories">
        <i class="fas fa-headphones coll-stat__icon"></i>
        <span class="coll-stat__value">{{ total_accessories }}</span>
        <span class="coll-stat__label">Accessoires</span>
    </div>
</div>

{# ---- Panneau d'ajout ---- #}
<div class="kit-add-panel">
    <div class="kit-add-panel__header">
        <i class="fas fa-plus-circle"></i>
        <span>Ajouter au kit</span>
    </div>
    <div class="kit-add-panel__body">
        {# Sélecteur de type #}
        <div class="kit-type-tabs" role="tablist">
            <button class="kit-type-tab kit-type-tab--active" data-target="game" role="tab">
                <i class="fas fa-gamepad"></i> Jeu
            </button>
            <button class="kit-type-tab" data-target="console" role="tab">
                <i class="fas fa-desktop"></i> Console
            </button>
            <button class="kit-type-tab" data-target="accessory" role="tab">
                <i class="fas fa-headphones"></i> Accessoire
            </button>
        </div>

        {# Formulaire de recherche — un seul affiché à la fois #}
        <div class="kit-add-fields">

            <div class="kit-add-type kit-add-type--active" id="add-game">
                <div class="kit-add-search">
                    <label class="coll-label"><i class="fas fa-search"></i> Rechercher un jeu</label>
                    <select id="game-select" class="kit-ts-select" placeholder="Tapez au moins 2 caractères…"></select>
                    <p class="kit-add-search__hint"><i class="fas fa-info-circle"></i> Tapez au moins 2 caractères pour lancer la recherche</p>
                </div>
                <div class="kit-add-meta">
                    <div class="coll-control-row">
                        <label class="coll-label"><i class="fas fa-layer-group"></i> Quantité</label>
                        <input type="number" class="coll-input" id="game-qty-input" value="1" min="1">
                    </div>
                    <div class="coll-control-row">
                        <label class="coll-label"><i class="fas fa-sticky-note"></i> Note</label>
                        <textarea class="coll-textarea" id="game-note-input" placeholder="État, câbles inclus…" rows="2"></textarea>
                    </div>
                </div>
                <button type="button" class="btn-primary kit-add-btn" data-type="game">
                    <i class="fas fa-plus"></i> Ajouter ce jeu
                </button>
            </div>

            <div class="kit-add-type" id="add-console">
                <div class="kit-add-search">
                    <label class="coll-label"><i class="fas fa-search"></i> Rechercher une console</label>
                    <select id="console-select" class="kit-ts-select" placeholder="Tapez au moins 2 caractères…"></select>
                    <p class="kit-add-search__hint"><i class="fas fa-info-circle"></i> Tapez au moins 2 caractères pour lancer la recherche</p>
                </div>
                <div class="kit-add-meta">
                    <div class="coll-control-row">
                        <label class="coll-label"><i class="fas fa-layer-group"></i> Quantité</label>
                        <input type="number" class="coll-input" id="console-qty-input" value="1" min="1">
                    </div>
                    <div class="coll-control-row">
                        <label class="coll-label"><i class="fas fa-sticky-note"></i> Note</label>
                        <textarea class="coll-textarea" id="console-note-input" placeholder="État, câbles inclus…" rows="2"></textarea>
                    </div>
                </div>
                <button type="button" class="btn-secondary kit-add-btn" data-type="console">
                    <i class="fas fa-plus"></i> Ajouter cette console
                </button>
            </div>

            <div class="kit-add-type" id="add-accessory">
                <div class="kit-add-search">
                    <label class="coll-label"><i class="fas fa-search"></i> Rechercher un accessoire</label>
                    <select id="accessory-select" class="kit-ts-select" placeholder="Tapez au moins 2 caractères…"></select>
                    <p class="kit-add-search__hint"><i class="fas fa-info-circle"></i> Tapez au moins 2 caractères pour lancer la recherche</p>
                </div>
                <div class="kit-add-meta">
                    <div class="coll-control-row">
                        <label class="coll-label"><i class="fas fa-layer-group"></i> Quantité</label>
                        <input type="number" class="coll-input" id="accessory-qty-input" value="1" min="1">
                    </div>
                    <div class="coll-control-row">
                        <label class="coll-label"><i class="fas fa-sticky-note"></i> Note</label>
                        <textarea class="coll-textarea" id="accessory-note-input" placeholder="État, câbles inclus…" rows="2"></textarea>
                    </div>
                </div>
                <button type="button" class="btn-outline kit-add-btn" data-type="accessory">
                    <i class="fas fa-plus"></i> Ajouter cet accessoire
                </button>
            </div>

        </div>
    </div>
</div>

{# ---- Onglets de liste ---- #}
<div class="coll-tabs" role="tablist">
    <button class="coll-tab coll-tab--active" data-tab="games" role="tab">
        <i class="fas fa-gamepad"></i>
        <span>Jeux</span>
        <span class="coll-tab__count">{{ game_kits|length }}</span>
    </button>
    <button class="coll-tab" data-tab="consoles" role="tab">
        <i class="fas fa-desktop"></i>
        <span>Consoles</span>
        <span class="coll-tab__count">{{ console_kits|length }}</span>
    </button>
    <button class="coll-tab" data-tab="accessories" role="tab">
        <i class="fas fa-headphones"></i>
        <span>Accessoires</span>
        <span class="coll-tab__count">{{ accessory_kits|length }}</span>
    </button>
</div>

{# ---- Panneau Jeux ---- #}
<div class="coll-panel coll-panel--active" id="tab-games" role="tabpanel">
    {% if game_kits %}
        <div class="coll-grid">
            {% for kit in game_kits %}
            <div class="coll-card" data-kit-id="{{ kit.id }}">
                <div class="coll-card__media">
                    {% if kit.game.image %}
                        <img src="{{ kit.game.image }}" alt="{{ kit.game.title }}" class="coll-card__img">
                    {% else %}
                        <div class="coll-card__placeholder coll-card__placeholder--games">
                            <i class="fas fa-gamepad"></i>
                        </div>
                    {% endif %}
                    <span class="coll-card__type-badge coll-card__type-badge--games">Kit</span>
                    {% if kit.quantity > 1 %}
                        <span class="coll-card__qty-badge">×{{ kit.quantity }}</span>
                    {% endif %}
                </div>
                <div class="coll-card__body">
                    <h3 class="coll-card__title">{{ kit.game.title }}</h3>
                    <p class="coll-card__sub">{{ kit.game.platform.name ?? 'N/A' }}</p>
                    <div class="coll-card__controls">
                        <div class="coll-control-row">
                            <label class="coll-label"><i class="fas fa-layer-group"></i> Quantité</label>
                            <input type="number" class="coll-input quantity-input"
                                   value="{{ kit.quantity }}" min="1"
                                   data-type="game" data-id="{{ kit.id }}">
                        </div>
                        <div class="coll-control-row">
                            <label class="coll-label"><i class="fas fa-sticky-note"></i> Note</label>
                            <textarea class="coll-textarea note-input" rows="2"
                                      data-type="game" data-id="{{ kit.id }}"
                                      placeholder="État, câbles inclus…">{{ kit.note }}</textarea>
                        </div>
                    </div>
                </div>
                <div class="coll-card__footer">
                    <button class="btn-primary btn-sm update-btn" data-type="game" data-id="{{ kit.id }}">
                        <i class="fas fa-save"></i> Sauvegarder
                    </button>
                    <button class="btn-danger btn-sm delete-btn" data-type="game" data-id="{{ kit.id }}" title="Retirer du kit">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </div>
            </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="coll-empty">
            <i class="fas fa-gamepad coll-empty__icon"></i>
            <p class="coll-empty__text">Aucun jeu dans votre kit</p>
            <a href="{{ path('app_game_index') }}" class="btn-primary">
                <i class="fas fa-search"></i> Parcourir les jeux
            </a>
        </div>
    {% endif %}
</div>

{# ---- Panneau Consoles ---- #}
<div class="coll-panel" id="tab-consoles" role="tabpanel">
    {% if console_kits %}
        <div class="coll-grid">
            {% for kit in console_kits %}
            <div class="coll-card" data-kit-id="{{ kit.id }}">
                <div class="coll-card__media">
                    {% if kit.console.image %}
                        <img src="{{ kit.console.image }}" alt="{{ kit.console.name }}" class="coll-card__img">
                    {% else %}
                        <div class="coll-card__placeholder coll-card__placeholder--consoles">
                            <i class="fas fa-desktop"></i>
                        </div>
                    {% endif %}
                    <span class="coll-card__type-badge coll-card__type-badge--consoles">Kit</span>
                    {% if kit.quantity > 1 %}
                        <span class="coll-card__qty-badge">×{{ kit.quantity }}</span>
                    {% endif %}
                </div>
                <div class="coll-card__body">
                    <h3 class="coll-card__title">{{ kit.console.name }}</h3>
                    <p class="coll-card__sub">{{ kit.console.manufacturer ?? 'N/A' }}</p>
                    <div class="coll-card__controls">
                        <div class="coll-control-row">
                            <label class="coll-label"><i class="fas fa-layer-group"></i> Quantité</label>
                            <input type="number" class="coll-input quantity-input"
                                   value="{{ kit.quantity }}" min="1"
                                   data-type="console" data-id="{{ kit.id }}">
                        </div>
                        <div class="coll-control-row">
                            <label class="coll-label"><i class="fas fa-sticky-note"></i> Note</label>
                            <textarea class="coll-textarea note-input" rows="2"
                                      data-type="console" data-id="{{ kit.id }}"
                                      placeholder="État, câbles inclus…">{{ kit.note }}</textarea>
                        </div>
                    </div>
                </div>
                <div class="coll-card__footer">
                    <button class="btn-secondary btn-sm update-btn" data-type="console" data-id="{{ kit.id }}">
                        <i class="fas fa-save"></i> Sauvegarder
                    </button>
                    <button class="btn-danger btn-sm delete-btn" data-type="console" data-id="{{ kit.id }}" title="Retirer du kit">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </div>
            </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="coll-empty">
            <i class="fas fa-desktop coll-empty__icon"></i>
            <p class="coll-empty__text">Aucune console dans votre kit</p>
            <a href="{{ path('app_console_index') }}" class="btn-secondary">
                <i class="fas fa-search"></i> Parcourir les consoles
            </a>
        </div>
    {% endif %}
</div>

{# ---- Panneau Accessoires ---- #}
<div class="coll-panel" id="tab-accessories" role="tabpanel">
    {% if accessory_kits %}
        <div class="coll-grid">
            {% for kit in accessory_kits %}
            <div class="coll-card" data-kit-id="{{ kit.id }}">
                <div class="coll-card__media">
                    {% if kit.accessory.image %}
                        <img src="{{ kit.accessory.image }}" alt="{{ kit.accessory.name }}" class="coll-card__img">
                    {% else %}
                        <div class="coll-card__placeholder coll-card__placeholder--accessories">
                            <i class="fas fa-headphones"></i>
                        </div>
                    {% endif %}
                    <span class="coll-card__type-badge coll-card__type-badge--accessories">Kit</span>
                    {% if kit.quantity > 1 %}
                        <span class="coll-card__qty-badge">×{{ kit.quantity }}</span>
                    {% endif %}
                </div>
                <div class="coll-card__body">
                    <h3 class="coll-card__title">{{ kit.accessory.name }}</h3>
                    <p class="coll-card__sub">{{ kit.accessory.type ?? 'N/A' }}</p>
                    <div class="coll-card__controls">
                        <div class="coll-control-row">
                            <label class="coll-label"><i class="fas fa-layer-group"></i> Quantité</label>
                            <input type="number" class="coll-input quantity-input"
                                   value="{{ kit.quantity }}" min="1"
                                   data-type="accessory" data-id="{{ kit.id }}">
                        </div>
                        <div class="coll-control-row">
                            <label class="coll-label"><i class="fas fa-sticky-note"></i> Note</label>
                            <textarea class="coll-textarea note-input" rows="2"
                                      data-type="accessory" data-id="{{ kit.id }}"
                                      placeholder="État, câbles inclus…">{{ kit.note }}</textarea>
                        </div>
                    </div>
                </div>
                <div class="coll-card__footer">
                    <button class="btn-outline btn-sm update-btn" data-type="accessory" data-id="{{ kit.id }}">
                        <i class="fas fa-save"></i> Sauvegarder
                    </button>
                    <button class="btn-danger btn-sm delete-btn" data-type="accessory" data-id="{{ kit.id }}" title="Retirer du kit">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </div>
            </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="coll-empty">
            <i class="fas fa-headphones coll-empty__icon"></i>
            <p class="coll-empty__text">Aucun accessoire dans votre kit</p>
            <a href="{{ path('app_accessory_index') }}" class="btn-outline">
                <i class="fas fa-search"></i> Parcourir les accessoires
            </a>
        </div>
    {% endif %}
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('kit') }}
{% endblock %}

