{% extends 'base.html.twig' %}

{% block title %}Ma Collection - {{ parent() }}{% endblock %}

{% block body %}

{# ---- Header ---- #}
<div class="coll-hero">
    <div class="coll-hero__icon">
        <i class="fas fa-box-open"></i>
    </div>
    <div class="coll-hero__text">
        <h1 class="coll-hero__title">Ma Collection</h1>
        <p class="coll-hero__sub">Gérez vos jeux, consoles et accessoires</p>
    </div>
    <a href="{{ path('app_collection_index') }}" class="btn-outline coll-hero__back">
        <i class="fas fa-arrow-left"></i> Retour
    </a>
</div>

{# ---- Stats ---- #}
<div class="coll-stats">
    <div class="coll-stat coll-stat--games">
        <i class="fas fa-gamepad coll-stat__icon"></i>
        <span class="coll-stat__value">{{ total_games }}</span>
        <span class="coll-stat__label">Jeux</span>
    </div>
    <div class="coll-stat coll-stat--consoles">
        <i class="fas fa-desktop coll-stat__icon"></i>
        <span class="coll-stat__value">{{ total_consoles }}</span>
        <span class="coll-stat__label">Consoles</span>
    </div>
    <div class="coll-stat coll-stat--accessories">
        <i class="fas fa-headphones coll-stat__icon"></i>
        <span class="coll-stat__value">{{ total_accessories }}</span>
        <span class="coll-stat__label">Accessoires</span>
    </div>
</div>

{# ---- Tabs ---- #}
<div class="coll-tabs" role="tablist">
    <button class="coll-tab coll-tab--active" data-tab="games" role="tab">
        <i class="fas fa-gamepad"></i>
        <span>Jeux</span>
        <span class="coll-tab__count">{{ game_collections|length }}</span>
    </button>
    <button class="coll-tab" data-tab="consoles" role="tab">
        <i class="fas fa-desktop"></i>
        <span>Consoles</span>
        <span class="coll-tab__count">{{ console_collections|length }}</span>
    </button>
    <button class="coll-tab" data-tab="accessories" role="tab">
        <i class="fas fa-headphones"></i>
        <span>Accessoires</span>
        <span class="coll-tab__count">{{ accessory_collections|length }}</span>
    </button>
</div>

{# ---- Panneau Jeux ---- #}
<div class="coll-panel coll-panel--active" id="tab-games" role="tabpanel">
    {% if game_collections %}
        <div class="coll-grid">
            {% for collection in game_collections %}
            <div class="coll-card" data-collection-id="{{ collection.id }}">
                <div class="coll-card__media">
                    {% if collection.game.image %}
                        <img src="{{ collection.game.image }}" alt="{{ collection.game.title }}" class="coll-card__img">
                    {% else %}
                        <div class="coll-card__placeholder coll-card__placeholder--games">
                            <i class="fas fa-gamepad"></i>
                        </div>
                    {% endif %}
                    <span class="coll-card__type-badge coll-card__type-badge--games">Jeu</span>
                </div>
                <div class="coll-card__body">
                    <h3 class="coll-card__title">{{ collection.game.title }}</h3>
                    <p class="coll-card__sub">{{ collection.game.platform.name ?? 'N/A' }}</p>
                    <div class="coll-card__controls">
                        <div class="coll-control-row">
                            <label class="coll-label"><i class="fas fa-layer-group"></i> Quantité</label>
                            <input type="number" class="coll-input quantity-input"
                                   value="{{ collection.quantity }}" min="1"
                                   data-type="game" data-id="{{ collection.id }}">
                        </div>
                        <div class="coll-control-row">
                            <label class="coll-label"><i class="fas fa-sticky-note"></i> Note</label>
                            <textarea class="coll-textarea note-input" rows="2"
                                      data-type="game" data-id="{{ collection.id }}"
                                      placeholder="État, provenance...">{{ collection.note }}</textarea>
                        </div>
                    </div>
                </div>
                <div class="coll-card__footer">
                    <button class="btn-primary btn-sm update-btn" data-type="game" data-id="{{ collection.id }}">
                        <i class="fas fa-save"></i> Sauvegarder
                    </button>
                    <button class="btn-danger btn-sm delete-btn" data-type="game" data-id="{{ collection.id }}" title="Retirer">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </div>
            </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="coll-empty">
            <i class="fas fa-gamepad coll-empty__icon"></i>
            <p class="coll-empty__text">Aucun jeu dans votre collection</p>
            <a href="{{ path('app_game_index') }}" class="btn-primary">
                <i class="fas fa-search"></i> Parcourir les jeux
            </a>
        </div>
    {% endif %}
</div>

{# ---- Panneau Consoles ---- #}
<div class="coll-panel" id="tab-consoles" role="tabpanel">
    {% if console_collections %}
        <div class="coll-grid">
            {% for collection in console_collections %}
            <div class="coll-card" data-collection-id="{{ collection.id }}">
                <div class="coll-card__media">
                    {% if collection.console.image %}
                        <img src="{{ collection.console.image }}" alt="{{ collection.console.name }}" class="coll-card__img">
                    {% else %}
                        <div class="coll-card__placeholder coll-card__placeholder--consoles">
                            <i class="fas fa-desktop"></i>
                        </div>
                    {% endif %}
                    <span class="coll-card__type-badge coll-card__type-badge--consoles">Console</span>
                </div>
                <div class="coll-card__body">
                    <h3 class="coll-card__title">{{ collection.console.name }}</h3>
                    <p class="coll-card__sub">{{ collection.console.manufacturer ?? 'N/A' }}</p>
                    <div class="coll-card__controls">
                        <div class="coll-control-row">
                            <label class="coll-label"><i class="fas fa-layer-group"></i> Quantité</label>
                            <input type="number" class="coll-input quantity-input"
                                   value="{{ collection.quantity }}" min="1"
                                   data-type="console" data-id="{{ collection.id }}">
                        </div>
                        <div class="coll-control-row">
                            <label class="coll-label"><i class="fas fa-sticky-note"></i> Note</label>
                            <textarea class="coll-textarea note-input" rows="2"
                                      data-type="console" data-id="{{ collection.id }}"
                                      placeholder="État, provenance...">{{ collection.note }}</textarea>
                        </div>
                    </div>
                </div>
                <div class="coll-card__footer">
                    <button class="btn-secondary btn-sm update-btn" data-type="console" data-id="{{ collection.id }}">
                        <i class="fas fa-save"></i> Sauvegarder
                    </button>
                    <button class="btn-danger btn-sm delete-btn" data-type="console" data-id="{{ collection.id }}" title="Retirer">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </div>
            </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="coll-empty">
            <i class="fas fa-desktop coll-empty__icon"></i>
            <p class="coll-empty__text">Aucune console dans votre collection</p>
            <a href="{{ path('app_console_index') }}" class="btn-secondary">
                <i class="fas fa-search"></i> Parcourir les consoles
            </a>
        </div>
    {% endif %}
</div>

{# ---- Panneau Accessoires ---- #}
<div class="coll-panel" id="tab-accessories" role="tabpanel">
    {% if accessory_collections %}
        <div class="coll-grid">
            {% for collection in accessory_collections %}
            <div class="coll-card" data-collection-id="{{ collection.id }}">
                <div class="coll-card__media">
                    {% if collection.accessory.image %}
                        <img src="{{ collection.accessory.image }}" alt="{{ collection.accessory.name }}" class="coll-card__img">
                    {% else %}
                        <div class="coll-card__placeholder coll-card__placeholder--accessories">
                            <i class="fas fa-headphones"></i>
                        </div>
                    {% endif %}
                    <span class="coll-card__type-badge coll-card__type-badge--accessories">Accessoire</span>
                </div>
                <div class="coll-card__body">
                    <h3 class="coll-card__title">{{ collection.accessory.name }}</h3>
                    <p class="coll-card__sub">{{ collection.accessory.type ?? 'N/A' }}</p>
                    <div class="coll-card__controls">
                        <div class="coll-control-row">
                            <label class="coll-label"><i class="fas fa-layer-group"></i> Quantité</label>
                            <input type="number" class="coll-input quantity-input"
                                   value="{{ collection.quantity }}" min="1"
                                   data-type="accessory" data-id="{{ collection.id }}">
                        </div>
                        <div class="coll-control-row">
                            <label class="coll-label"><i class="fas fa-sticky-note"></i> Note</label>
                            <textarea class="coll-textarea note-input" rows="2"
                                      data-type="accessory" data-id="{{ collection.id }}"
                                      placeholder="État, provenance...">{{ collection.note }}</textarea>
                        </div>
                    </div>
                </div>
                <div class="coll-card__footer">
                    <button class="btn-danger btn-sm update-btn" data-type="accessory" data-id="{{ collection.id }}">
                        <i class="fas fa-save"></i> Sauvegarder
                    </button>
                    <button class="btn-danger btn-sm delete-btn" data-type="accessory" data-id="{{ collection.id }}" title="Retirer">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </div>
            </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="coll-empty">
            <i class="fas fa-headphones coll-empty__icon"></i>
            <p class="coll-empty__text">Aucun accessoire dans votre collection</p>
            <a href="{{ path('app_accessory_index') }}" class="btn-outline">
                <i class="fas fa-search"></i> Parcourir les accessoires
            </a>
        </div>
    {% endif %}
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// ---- Système d'onglets ----
document.querySelectorAll('.coll-tab').forEach(tab => {
    tab.addEventListener('click', function() {
        const target = this.dataset.tab;
        document.querySelectorAll('.coll-tab').forEach(t => t.classList.remove('coll-tab--active'));
        document.querySelectorAll('.coll-panel').forEach(p => p.classList.remove('coll-panel--active'));
        this.classList.add('coll-tab--active');
        document.getElementById('tab-' + target).classList.add('coll-panel--active');
    });
});

// ---- AJAX : sauvegarder ----
document.querySelectorAll('.update-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        const type = this.dataset.type;
        const id = this.dataset.id;
        const card = this.closest('[data-collection-id]');
        const quantity = card.querySelector('.quantity-input').value;
        const note = card.querySelector('.note-input').value;
        const originalHtml = this.innerHTML;
        this.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
        this.disabled = true;

        fetch(`/collection/${type}/${id}/update`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `quantity=${quantity}&note=${encodeURIComponent(note)}`
        })
        .then(r => r.json())
        .then(data => {
            this.innerHTML = data.success ? '<i class="fas fa-check"></i> Sauvegardé' : originalHtml;
            setTimeout(() => { this.innerHTML = originalHtml; this.disabled = false; }, 2000);
        })
        .catch(() => { this.innerHTML = originalHtml; this.disabled = false; });
    });
});

// ---- AJAX : supprimer ----
document.querySelectorAll('.delete-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        if (!confirm('Retirer cet élément de votre collection ?')) return;
        const type = this.dataset.type;
        const id = this.dataset.id;
        const card = this.closest('[data-collection-id]');

        fetch(`/collection/${type}/${id}/delete`, { method: 'POST' })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                card.style.transition = 'opacity 0.3s, transform 0.3s';
                card.style.opacity = '0';
                card.style.transform = 'scale(0.9)';
                setTimeout(() => { card.remove(); }, 300);
            }
        })
        .catch(() => {});
    });
});
</script>
{% endblock %}
