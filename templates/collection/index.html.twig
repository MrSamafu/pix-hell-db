{% extends 'base.html.twig' %}

{% block title %}Collections - {{ parent() }}{% endblock %}

{% block body %}
    <div class="page-header">
        <div class="page-header-content">
            <h1 class="page-title">
                <span class="icon">📦</span>
                Collections
            </h1>
        </div>
    </div>

    <div class="container">

        {# === Ma Collection (Hero Card) === #}
        <div class="coll-hero-card mb-xl">
            <div class="coll-hero-card__visual">
                <span class="coll-hero-card__emoji">🎮</span>
                <div class="coll-hero-card__glow"></div>
            </div>
            <div class="coll-hero-card__content">
                <h2 class="coll-hero-card__title">Ma Collection</h2>
                <p class="coll-hero-card__desc">
                    Gérez votre collection personnelle de jeux, consoles et accessoires.
                </p>
                <a href="{{ path('app_collection_my') }}" class="btn btn--primary">
                    <i class="fas fa-folder-open"></i> Voir ma collection
                </a>
            </div>
        </div>

        {# === Grille inférieure : Utilisateurs + Recherche === #}
        <div class="coll-bottom-grid mb-xl">

            {# --- Utilisateurs --- #}
            <div class="coll-panel">
                <div class="coll-panel__header">
                    <span class="coll-panel__icon">👥</span>
                    <h2 class="coll-panel__title">Collectionneurs</h2>
                    <span class="badge badge--secondary">{{ users|length }}</span>
                </div>
                <div class="coll-panel__body">
                    {% if users|length == 0 %}
                        <p class="text--muted text--center">Aucun autre collectionneur</p>
                    {% else %}
                        <ul class="coll-user-list">
                            {% for user in users %}
                                <li>
                                    <a href="{{ path('app_collection_user', {'id': user.id}) }}" class="coll-user-item">
                                        <span class="coll-user-item__avatar">
                                            <i class="fas fa-user"></i>
                                        </span>
                                        <span class="coll-user-item__name">{{ user.username }}</span>
                                        <i class="fas fa-chevron-right coll-user-item__arrow"></i>
                                    </a>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            </div>

            {# --- Recherche --- #}
            <div class="coll-panel">
                <div class="coll-panel__header">
                    <span class="coll-panel__icon">🔍</span>
                    <h2 class="coll-panel__title">Recherche</h2>
                </div>
                <div class="coll-panel__body">
                    <p class="text--muted mb-md" style="font-size: 0.9rem;">
                        Trouvez qui possède un jeu, une console ou un accessoire
                    </p>
                    <form action="{{ path('app_collection_search') }}" method="get" class="coll-search-form">
                        <div class="form__group">
                            <label for="search-query" class="form__label">Nom de l'objet</label>
                            <div class="coll-search-input-wrap">
                                <i class="fas fa-search coll-search-input-wrap__icon"></i>
                                <input type="text"
                                       class="form__input coll-search-input-wrap__input"
                                       id="search-query"
                                       name="q"
                                       placeholder="ex: Super Mario, Game Boy..."
                                       required>
                            </div>
                        </div>
                        <div class="form__group">
                            <label for="search-type" class="form__label">Catégorie</label>
                            <select class="form__select" id="search-type" name="type">
                                <option value="all">🗂 Toutes catégories</option>
                                <option value="game">🎮 Jeux</option>
                                <option value="console">🖥 Consoles</option>
                                <option value="accessory">🔌 Accessoires</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn--accent" style="width:100%;">
                            <i class="fas fa-search"></i> Lancer la recherche
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>
{% endblock %}
