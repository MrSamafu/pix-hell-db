{% extends 'base.html.twig' %}

{% block title %}Gestion des utilisateurs - Admin - {{ parent() }}{% endblock %}

{% block body %}

{# ---- Header ---- #}
<div class="admin-hero admin-hero--users">
    <div class="admin-hero__icon">
        <i class="fas fa-users-cog"></i>
    </div>
    <div class="admin-hero__text">
        <h1 class="admin-hero__title">Gestion des utilisateurs</h1>
        <p class="admin-hero__sub">{{ users|length }} membre(s) inscrit(s)</p>
    </div>
    <a href="{{ path('app_admin_dashboard') }}" class="btn-outline admin-hero__back">
        <i class="fas fa-arrow-left"></i> Dashboard
    </a>
</div>

{# ---- Vue MOBILE : cartes ---- #}
<div class="user-cards hide-desktop">
    {% for user in users %}
    <div class="user-card">
        <div class="user-card__top">
            <div class="user-card__avatar">
                <i class="fas fa-user"></i>
            </div>
            <div class="user-card__identity">
                <strong class="user-card__username">{{ user.username }}</strong>
                {% if user.firstName or user.lastName %}
                    <span class="user-card__fullname">{{ user.firstName }} {{ user.lastName }}</span>
                {% endif %}
                <span class="user-card__email">{{ user.email }}</span>
            </div>
            <div class="user-card__role">
                {% if 'ROLE_ADMIN' in user.roles %}
                    <span class="user-badge user-badge--admin"><i class="fas fa-shield-alt"></i> Admin</span>
                {% else %}
                    <span class="user-badge user-badge--user"><i class="fas fa-user"></i> Membre</span>
                {% endif %}
            </div>
        </div>

        <div class="user-card__stats">
            <div class="user-card__stat">
                <i class="fas fa-trophy"></i>
                <span>{{ user.badges|length }}</span>
                <small>Badges</small>
            </div>
            <div class="user-card__stat">
                <i class="fas fa-gamepad"></i>
                <span>{{ user.gameCollections|length }}</span>
                <small>Jeux</small>
            </div>
            <div class="user-card__stat">
                <i class="fas fa-desktop"></i>
                <span>{{ user.consoleCollections|length }}</span>
                <small>Consoles</small>
            </div>
            <div class="user-card__stat">
                <i class="fas fa-puzzle-piece"></i>
                <span>{{ user.accessoryCollections|length }}</span>
                <small>Acces.</small>
            </div>
        </div>

        <div class="user-card__actions">
            <a href="{{ path('app_user_profile', {'id': user.id}) }}" class="btn-outline btn-sm" title="Voir le profil">
                <i class="fas fa-eye"></i> Profil
            </a>
            <a href="{{ path('app_admin_user_manage_badges', {'id': user.id}) }}" class="btn-secondary btn-sm" title="Gérer les badges">
                <i class="fas fa-trophy"></i> Badges
            </a>
            <form method="post" action="{{ path('app_admin_user_toggle_admin', {'id': user.id}) }}" class="inline-form"
                  onsubmit="return confirm('Modifier les droits de cet utilisateur ?')">
                <input type="hidden" name="_token" value="{{ csrf_token('toggle_admin_' ~ user.id) }}">
                {% if 'ROLE_ADMIN' in user.roles %}
                    <button type="submit" class="btn-danger btn-sm" title="Retirer admin">
                        <i class="fas fa-user-shield"></i> Rétrograder
                    </button>
                {% else %}
                    <button type="submit" class="btn-primary btn-sm" title="Promouvoir admin">
                        <i class="fas fa-user-plus"></i> Promouvoir
                    </button>
                {% endif %}
            </form>
        </div>
    </div>
    {% else %}
    <div class="empty-state">
        <div class="empty-state-icon"><i class="fas fa-users"></i></div>
        <p class="empty-state-title">Aucun utilisateur trouvé.</p>
    </div>
    {% endfor %}
</div>

{# ---- Vue DESKTOP : tableau ---- #}
<div class="admin-table-wrap hide-mobile">
    <table class="admin-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Utilisateur</th>
                <th>Email</th>
                <th>Rôle</th>
                <th>Badges</th>
                <th>Collection</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for user in users %}
            <tr>
                <td class="admin-table__id">#{{ user.id }}</td>
                <td>
                    <div class="admin-table__user">
                        <div class="admin-table__avatar">
                            <i class="fas fa-user"></i>
                        </div>
                        <div>
                            <strong>{{ user.username }}</strong>
                            {% if user.firstName or user.lastName %}
                                <br><small>{{ user.firstName }} {{ user.lastName }}</small>
                            {% endif %}
                        </div>
                    </div>
                </td>
                <td><small>{{ user.email }}</small></td>
                <td>
                    {% if 'ROLE_ADMIN' in user.roles %}
                        <span class="user-badge user-badge--admin"><i class="fas fa-shield-alt"></i> Admin</span>
                    {% else %}
                        <span class="user-badge user-badge--user"><i class="fas fa-user"></i> Membre</span>
                    {% endif %}
                </td>
                <td>
                    <span class="user-badge user-badge--gold"><i class="fas fa-trophy"></i> {{ user.badges|length }}</span>
                </td>
                <td>
                    <div class="admin-table__collection">
                        <span class="coll-chip coll-chip--games" title="Jeux">
                            <i class="fas fa-gamepad"></i> {{ user.gameCollections|length }}
                        </span>
                        <span class="coll-chip coll-chip--consoles" title="Consoles">
                            <i class="fas fa-desktop"></i> {{ user.consoleCollections|length }}
                        </span>
                        <span class="coll-chip coll-chip--accessories" title="Accessoires">
                            <i class="fas fa-puzzle-piece"></i> {{ user.accessoryCollections|length }}
                        </span>
                    </div>
                </td>
                <td>
                    <div class="admin-table__actions">
                        <a href="{{ path('app_user_profile', {'id': user.id}) }}" class="action-btn action-btn--view" title="Voir le profil">
                            <i class="fas fa-eye"></i>
                        </a>
                        <a href="{{ path('app_admin_user_manage_badges', {'id': user.id}) }}" class="action-btn action-btn--badge" title="Gérer les badges">
                            <i class="fas fa-trophy"></i>
                        </a>
                        <form method="post" action="{{ path('app_admin_user_toggle_admin', {'id': user.id}) }}" class="inline-form"
                              onsubmit="return confirm('Modifier les droits de cet utilisateur ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle_admin_' ~ user.id) }}">
                            {% if 'ROLE_ADMIN' in user.roles %}
                                <button type="submit" class="action-btn action-btn--demote" title="Retirer admin">
                                    <i class="fas fa-user-shield"></i>
                                </button>
                            {% else %}
                                <button type="submit" class="action-btn action-btn--promote" title="Promouvoir admin">
                                    <i class="fas fa-user-plus"></i>
                                </button>
                            {% endif %}
                        </form>
                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="7">
                    <div class="empty-state">
                        <div class="empty-state-icon"><i class="fas fa-users"></i></div>
                        <p class="empty-state-title">Aucun utilisateur trouvé.</p>
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}
