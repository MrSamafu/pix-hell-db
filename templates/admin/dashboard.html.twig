{% extends 'base.html.twig' %}

{% block title %}Administration - {{ parent() }}{% endblock %}

{% block body %}

<div class="admin-hero">
    <div class="admin-hero__icon">
        <i class="fas fa-shield-alt"></i>
    </div>
    <div class="admin-hero__text">
        <h1 class="admin-hero__title">Panneau d'Administration</h1>
        <p class="admin-hero__sub">Gérez votre application Pix Hell DB</p>
    </div>
</div>

{# Statistiques #}
<div class="admin-stats">
    <div class="admin-stat">
        <div class="admin-stat__icon admin-stat__icon--users">
            <i class="fas fa-users"></i>
        </div>
        <div class="admin-stat__body">
            <span class="admin-stat__value">{{ totalUsers }}</span>
            <span class="admin-stat__label">Utilisateurs</span>
        </div>
    </div>
    <div class="admin-stat">
        <div class="admin-stat__icon admin-stat__icon--badges">
            <i class="fas fa-trophy"></i>
        </div>
        <div class="admin-stat__body">
            <span class="admin-stat__value">{{ totalBadges }}</span>
            <span class="admin-stat__label">Badges</span>
        </div>
    </div>
    <div class="admin-stat">
        <div class="admin-stat__icon admin-stat__icon--games">
            <i class="fas fa-gamepad"></i>
        </div>
        <div class="admin-stat__body">
            <span class="admin-stat__value">—</span>
            <span class="admin-stat__label">Jeux</span>
        </div>
    </div>
    <div class="admin-stat">
        <div class="admin-stat__icon admin-stat__icon--consoles">
            <i class="fas fa-desktop"></i>
        </div>
        <div class="admin-stat__body">
            <span class="admin-stat__value">—</span>
            <span class="admin-stat__label">Consoles</span>
        </div>
    </div>
</div>

{# Actions rapides #}
<div class="admin-sections">

    <div class="admin-section">
        <div class="admin-section__header">
            <i class="fas fa-users"></i>
            <h2>Utilisateurs</h2>
        </div>
        <div class="admin-section__body">
            <p>Gérez les comptes, attribuez des rôles et des badges.</p>
            <div class="admin-section__actions">
                <a href="{{ path('app_admin_users') }}" class="btn-primary">
                    <i class="fas fa-list"></i> Liste des utilisateurs
                </a>
            </div>
        </div>
    </div>

    <div class="admin-section">
        <div class="admin-section__header">
            <i class="fas fa-trophy"></i>
            <h2>Badges</h2>
        </div>
        <div class="admin-section__body">
            <p>Créez, modifiez et supprimez des badges pour récompenser les membres.</p>
            <div class="admin-section__actions">
                <a href="{{ path('app_badge_index') }}" class="btn-secondary">
                    <i class="fas fa-list"></i> Gérer les badges
                </a>
                <a href="{{ path('app_badge_new') }}" class="btn-primary">
                    <i class="fas fa-plus"></i> Créer un badge
                </a>
            </div>
        </div>
    </div>

    <div class="admin-section">
        <div class="admin-section__header">
            <i class="fas fa-database"></i>
            <h2>Contenu</h2>
        </div>
        <div class="admin-section__body">
            <p>Gérez les jeux, consoles et accessoires de la base de données.</p>
            <div class="admin-section__actions">
                <a href="{{ path('app_game_index') }}" class="btn-outline">
                    <i class="fas fa-gamepad"></i> Jeux
                </a>
                <a href="{{ path('app_console_index') }}" class="btn-outline">
                    <i class="fas fa-desktop"></i> Consoles
                </a>
                <a href="{{ path('app_accessory_index') }}" class="btn-outline">
                    <i class="fas fa-puzzle-piece"></i> Accessoires
                </a>
            </div>
        </div>
    </div>

    <div class="admin-section admin-section--muted">
        <div class="admin-section__header">
            <i class="fas fa-chart-line"></i>
            <h2>Statistiques</h2>
        </div>
        <div class="admin-section__body">
            <p>Consultez les statistiques et rapports de l'application.</p>
            <div class="alert alert--info">
                <i class="fas fa-info-circle"></i> Fonctionnalité à venir prochainement.
            </div>
        </div>
    </div>

</div>

<div class="admin-footer-action">
    <a href="{{ path('app_home') }}" class="btn-outline">
        <i class="fas fa-home"></i> Retour à l'accueil
    </a>
</div>

{% endblock %}
